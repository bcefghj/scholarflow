# ScholarFlow Configuration
# Copy this file to .env and fill in your API keys

# === LLM API Keys (fill in at least one) ===
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
MINIMAX_API_KEY=

# === Default Settings ===
# Model to use (examples: openai/gpt-4o, minimax/MiniMax-M2.7, deepseek/deepseek-chat)
SF_MODEL=openai/gpt-4o

# Output language: zh (Chinese) or en (English)
SF_LANG=zh

# Verbosity: concise, normal, detailed
SF_VERBOSITY=normal

# PPT theme: academic_blue, minimal_white, dark_modern
SF_PPT_THEME=academic_blue

# Beamer theme: Madrid, Berlin, Singapore, CambridgeUS
SF_BEAMER_THEME=Madrid
