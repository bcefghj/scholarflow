\documentclass[aspectratio=169,12pt]{beamer}

\usetheme{<< theme >>}
\usecolortheme{default}

<% if lang == "zh" %>
\usepackage{ctex}
<% endif %>
\usepackage{amsmath,amssymb}
\usepackage{graphicx}
\usepackage{booktabs}

\setbeamertemplate{navigation symbols}{}
\setbeamertemplate{footline}[frame number]

\title{<< title >>}
\author{<< authors >>}
\date{<< year >>}
<% if venue %>
\institute{<< venue >>}
<% endif %>

\begin{document}

\begin{frame}
\titlepage
\end{frame}

<% for slide in slides %>
\begin{frame}{<< slide.title >>}
<% if slide.figure_path %>
\begin{columns}[T]
\begin{column}{0.55\textwidth}
<% if slide.bullets %>
\begin{itemize}
<% for bullet in slide.bullets %>
    \item << bullet >>
<% endfor %>
\end{itemize}
<% endif %>
\end{column}
\begin{column}{0.42\textwidth}
\centering
\includegraphics[width=\textwidth]{<< slide.figure_path >>}
<% if slide.figure_caption %>
\vspace{2mm}
{\tiny << slide.figure_caption >>}
<% endif %>
\end{column}
\end{columns}
<% else %>
<% if slide.bullets %>
\begin{itemize}
<% for bullet in slide.bullets %>
    \item << bullet >>
<% endfor %>
\end{itemize}
<% endif %>
<% endif %>
\end{frame}

<% endfor %>

\end{document}
