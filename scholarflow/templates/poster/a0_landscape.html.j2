<!DOCTYPE html>
<html lang="zh">
<head>
<meta charset="UTF-8">
<title>{{ title }} - Academic Poster</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Segoe UI', 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
         background: #e8ecf1; display: flex; justify-content: center; padding: 20px; }
  .poster { width: 1400px; background: white; box-shadow: 0 4px 24px rgba(0,0,0,0.12);
            border-radius: 10px; overflow: hidden; }
  .poster-header { background: linear-gradient(135deg, #1a3c6e 0%, #2e75b6 60%, #5ba3e6 100%);
                   color: white; padding: 35px 45px; text-align: center; }
  .poster-header h1 { font-size: 32px; margin-bottom: 12px; line-height: 1.3; font-weight: 700; }
  .poster-header .authors { font-size: 17px; opacity: 0.9; font-weight: 500; }
  .poster-header .affiliation { font-size: 14px; opacity: 0.7; margin-top: 6px; }
  .poster-body { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 22px; padding: 28px; }
  .section { background: #f8faff; border-radius: 8px; padding: 22px;
             border-left: 5px solid #2e75b6; transition: box-shadow 0.2s; }
  .section:hover { box-shadow: 0 2px 12px rgba(46,117,182,0.12); }
  .section h2 { color: #1a3c6e; font-size: 19px; margin-bottom: 14px;
                border-bottom: 2px solid #2e75b6; padding-bottom: 8px; font-weight: 700; }
  .section p { font-size: 13.5px; line-height: 1.7; color: #333; margin-bottom: 10px; }
  .section ul { font-size: 13.5px; line-height: 1.8; color: #333; padding-left: 20px; }
  .section.highlight { border-left-color: #e84d39; }
  .section.highlight h2 { color: #c0392b; border-bottom-color: #e84d39; }

  .figures-row { grid-column: 1 / -1; display: flex; gap: 16px; flex-wrap: wrap;
                 justify-content: center; background: #fafbfd; border-radius: 8px;
                 padding: 18px; border: 1px solid #e0e5ed; }
  .fig-card { flex: 1 1 280px; max-width: 420px; text-align: center; }
  .fig-card img { max-width: 100%; max-height: 280px; border-radius: 6px;
                  border: 1px solid #ddd; object-fit: contain; background: white; }
  .fig-card .caption { font-size: 11px; color: #666; margin-top: 6px; line-height: 1.4; }

  .conclusion-row { grid-column: 1 / 3; }
  .references { grid-column: 1 / -1; background: #f0f2f5; border-left-color: #888; }
  .references h2 { color: #555; border-bottom-color: #888; }
  .references ul { columns: 2; font-size: 11px; column-gap: 30px; }
</style>
</head>
<body>
<div class="poster">
  <div class="poster-header">
    <h1>{{ title }}</h1>
    <div class="authors">{{ authors }}</div>
    {% if affiliation %}<div class="affiliation">{{ affiliation }}</div>{% endif %}
  </div>
  <div class="poster-body">

    <div class="section">
      <h2>Introduction</h2>
      <p>{{ introduction }}</p>
      {% if problem %}<p><strong>Problem:</strong> {{ problem }}</p>{% endif %}
    </div>

    <div class="section highlight">
      <h2>Method</h2>
      <p>{{ method }}</p>
      {% if method_points %}
      <ul>{% for p in method_points %}<li>{{ p }}</li>{% endfor %}</ul>
      {% endif %}
    </div>

    <div class="section">
      <h2>Results</h2>
      <p>{{ results }}</p>
      {% if result_points %}
      <ul>{% for p in result_points %}<li>{{ p }}</li>{% endfor %}</ul>
      {% endif %}
    </div>

    {% if figures %}
    <div class="figures-row">
      {% for fig in figures %}
      <div class="fig-card">
        <img src="{{ fig.src }}" alt="{{ fig.caption }}">
        <div class="caption">{{ fig.caption }}</div>
      </div>
      {% endfor %}
    </div>
    {% endif %}

    <div class="section conclusion-row">
      <h2>Conclusion</h2>
      <p>{{ conclusion }}</p>
    </div>

    <div class="section references">
      <h2>References</h2>
      {% if references %}
      <ul>{% for r in references %}<li>{{ r }}</li>{% endfor %}</ul>
      {% endif %}
    </div>

  </div>
</div>
</body>
</html>
