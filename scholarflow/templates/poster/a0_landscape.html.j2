<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>{{ title }} - Academic Poster</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Segoe UI', 'Helvetica Neue', Arial, sans-serif; background: #f0f2f5;
         display: flex; justify-content: center; padding: 20px; }
  .poster { width: 1200px; background: white; box-shadow: 0 4px 20px rgba(0,0,0,0.15);
            border-radius: 8px; overflow: hidden; }
  .poster-header { background: linear-gradient(135deg, #1a3c6e, #2e75b6); color: white;
                   padding: 30px 40px; text-align: center; }
  .poster-header h1 { font-size: 28px; margin-bottom: 10px; line-height: 1.3; }
  .poster-header .authors { font-size: 16px; opacity: 0.9; }
  .poster-header .affiliation { font-size: 14px; opacity: 0.7; margin-top: 5px; }
  .poster-body { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; padding: 25px; }
  .section { background: #f8faff; border-radius: 6px; padding: 20px; border-left: 4px solid #2e75b6; }
  .section h2 { color: #1a3c6e; font-size: 18px; margin-bottom: 12px;
                border-bottom: 2px solid #2e75b6; padding-bottom: 6px; }
  .section p { font-size: 13px; line-height: 1.6; color: #333; margin-bottom: 8px; }
  .section ul { font-size: 13px; line-height: 1.8; color: #333; padding-left: 18px; }
  .section.highlight { border-left-color: #e84d39; }
  .section.highlight h2 { color: #c0392b; border-bottom-color: #e84d39; }
  .references { grid-column: 1 / -1; background: #f0f2f5; border-left-color: #888; }
  .references h2 { color: #555; border-bottom-color: #888; }
  .references ul { columns: 2; font-size: 11px; }
</style>
</head>
<body>
<div class="poster">
  <div class="poster-header">
    <h1>{{ title }}</h1>
    <div class="authors">{{ authors }}</div>
    {% if affiliation %}<div class="affiliation">{{ affiliation }}</div>{% endif %}
  </div>
  <div class="poster-body">
    <div class="section">
      <h2>Introduction</h2>
      <p>{{ introduction }}</p>
      {% if problem %}<p><strong>Problem:</strong> {{ problem }}</p>{% endif %}
    </div>
    <div class="section highlight">
      <h2>Method</h2>
      <p>{{ method }}</p>
      {% if method_points %}
      <ul>{% for p in method_points %}<li>{{ p }}</li>{% endfor %}</ul>
      {% endif %}
    </div>
    <div class="section">
      <h2>Results</h2>
      <p>{{ results }}</p>
      {% if result_points %}
      <ul>{% for p in result_points %}<li>{{ p }}</li>{% endfor %}</ul>
      {% endif %}
    </div>
    <div class="section" style="grid-column: 1 / 3;">
      <h2>Conclusion</h2>
      <p>{{ conclusion }}</p>
    </div>
    <div class="section references">
      <h2>References</h2>
      {% if references %}
      <ul>{% for r in references %}<li>{{ r }}</li>{% endfor %}</ul>
      {% endif %}
    </div>
  </div>
</div>
</body>
</html>
